<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.settings.siteTitle }}</title>
<link href="{{ site.settings.fontsUrl }}" rel="stylesheet">
<style>
:root {
  --night:     #1e2740;   /* ← lightened further */
  --deep:      #232e48;
  --cosmos:    #2a3655;
  --veil:      #303f60;
  --surface:   #384669;
  --gold:      #c9a84c;
  --gold-lt:   #e8c97a;
  --gold-pale: #f5e6b8;
  --blush:     #e8a0bf;
  --moon:      #d8e4ff;
  --mist:      rgba(216,228,255,0.65);
  --glow:      rgba(201,168,76,0.45);
  --stardust:  rgba(201,168,76,0.12);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--night);color:var(--moon);font-family:'Jost',sans-serif;font-weight:300;overflow-x:hidden;cursor:none;}

.cursor{width:10px;height:10px;background:var(--gold);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform 0.1s;mix-blend-mode:screen;}
.cursor-ring{width:32px;height:32px;border:1px solid rgba(201,168,76,0.5);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:all 0.15s ease;}

nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1.4rem 4rem;background:linear-gradient(to bottom,rgba(30,39,64,0.94) 0%,transparent 100%);backdrop-filter:blur(6px);}
.nav-logo{font-family:'Cinzel',serif;font-size:0.9rem;font-weight:600;letter-spacing:0.12em;color:var(--gold);text-decoration:none;text-transform:uppercase;}
.nav-logo span{color:var(--moon);font-weight:400;}
.nav-links{display:flex;gap:2.5rem;list-style:none;}
.nav-links a{font-family:'Jost',sans-serif;font-size:0.72rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:rgba(216,228,255,0.6);text-decoration:none;transition:color 0.3s;}
.nav-links a:hover{color:var(--gold-lt);}
.nav-cta{font-family:'Jost',sans-serif;font-size:0.7rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:var(--night);background:var(--gold);padding:0.55rem 1.4rem;text-decoration:none;transition:background 0.3s;}
.nav-cta:hover{background:var(--gold-lt);}

/* ═══ HERO ═══ */
.hero{position:relative;width:100%;height:100vh;min-height:640px;overflow:hidden;}
.hero-kailash{
  position:absolute;inset:0;
  background-image:url('{{ site.hero.backgroundImage }}');
  background-size:cover;background-position:center 40%;background-repeat:no-repeat;z-index:0;
}
.hero-kailash::after{
  content:'';position:absolute;inset:0;
  background:
    linear-gradient(to bottom,rgba(30,39,64,0.48) 0%,rgba(30,39,64,0.12) 35%,rgba(30,39,64,0.62) 75%,var(--night) 100%),
    linear-gradient(to right,rgba(30,39,64,0.22) 0%,transparent 35%,transparent 65%,rgba(30,39,64,0.22) 100%);
}
.hero-tint{position:absolute;inset:0;z-index:1;background:radial-gradient(ellipse at 50% 45%,rgba(201,168,76,0.07) 0%,transparent 60%);mix-blend-mode:screen;}
#constellationCanvas{position:absolute;inset:0;width:100%;height:100%;z-index:2;cursor:none;}
.hero-title{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);text-align:center;z-index:3;pointer-events:none;}
.hero-eyebrow{font-family:'Jost',sans-serif;font-size:0.65rem;font-weight:500;letter-spacing:0.42em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;opacity:0;animation:fadeUp 1s 0.3s forwards;}
.hero-title h1{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,7vw,7.5rem);font-weight:300;line-height:0.92;letter-spacing:-0.01em;color:var(--gold-pale);text-shadow:0 2px 40px rgba(0,0,0,0.7);opacity:0;animation:fadeUp 1.2s 0.5s forwards;}
.hero-title h1 em{display:block;font-style:italic;color:var(--gold-lt);}
.hero-hint{margin-top:1.6rem;font-family:'Jost',sans-serif;font-size:0.62rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(201,168,76,0.62);opacity:0;animation:fadeUp 1s 1.4s forwards;}
.hero-hint span{display:inline-block;animation:pulse-hint 2s ease-in-out 2s infinite;}
.star-tooltip{position:absolute;z-index:10;background:rgba(30,39,64,0.94);border:1px solid rgba(201,168,76,0.4);padding:0.7rem 1.1rem;pointer-events:none;opacity:0;transition:opacity 0.2s;backdrop-filter:blur(10px);}
.star-tooltip.visible{opacity:1;}
.star-tooltip-label{font-family:'Cinzel',serif;font-size:0.72rem;letter-spacing:0.15em;color:var(--gold-pale);text-transform:uppercase;white-space:nowrap;}
.star-tooltip-desc{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.85rem;color:var(--mist);margin-top:0.2rem;white-space:nowrap;}
.star-tooltip-cta{font-family:'Jost',sans-serif;font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);margin-top:0.4rem;}
.photo-credit{position:absolute;bottom:5rem;right:1.5rem;z-index:4;font-size:0.52rem;letter-spacing:0.1em;color:rgba(216,228,255,0.22);text-transform:uppercase;}
.scroll-down{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:4;display:flex;flex-direction:column;align-items:center;gap:0.4rem;opacity:0;animation:fadeUp 1s 2.2s forwards;}
.scroll-down-line{width:1px;height:48px;background:linear-gradient(to bottom,transparent,var(--gold));animation:scroll-pulse 2s ease-in-out infinite;}

/* ═══ Shared ═══ */
section{position:relative;z-index:1;}
.section-label{font-family:'Jost',sans-serif;font-size:0.62rem;font-weight:500;letter-spacing:0.45em;text-transform:uppercase;color:var(--gold);margin-bottom:0.8rem;}
.section-title{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:clamp(2.4rem,4.5vw,4rem);line-height:1;color:var(--gold-pale);}
.section-title em{font-style:italic;color:var(--gold-lt);}
.divider{width:70px;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);margin:1.8rem auto;}

/* ═══ Daily Cosmic ═══ */
.daily{padding:7rem 4rem;background:linear-gradient(to bottom,transparent,var(--deep) 15%,var(--deep) 85%,transparent);}
.daily-inner{max-width:1200px;margin:0 auto;}
.daily-header{text-align:center;margin-bottom:4.5rem;}

/* Alert banner for imminent retrograde */
.retro-alert{
  display:flex;align-items:center;gap:1rem;
  background:linear-gradient(135deg,rgba(201,168,76,0.12),rgba(201,168,76,0.04));
  border:1px solid rgba(201,168,76,0.35);
  padding:0.9rem 1.5rem;
  margin-bottom:3rem;
  max-width:1200px; margin-left:auto; margin-right:auto;
}
.retro-alert-icon{font-size:1.4rem;flex-shrink:0;}
.retro-alert-text{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;color:rgba(245,230,184,0.85);line-height:1.5;}
.retro-alert-text strong{font-style:normal;font-family:'Cinzel',serif;font-size:0.75rem;letter-spacing:0.15em;color:var(--gold);display:block;margin-bottom:0.2rem;}

.daily-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.12);}
.daily-panel{background:var(--cosmos);padding:3rem;position:relative;overflow:hidden;transition:background 0.4s;}
.daily-panel:hover{background:var(--veil);}
.daily-panel::before{content:'';position:absolute;top:0;right:0;width:200px;height:200px;background:radial-gradient(circle at top right,rgba(201,168,76,0.06),transparent 70%);}
.panel-icon{font-size:2.5rem;margin-bottom:1.2rem;display:block;filter:drop-shadow(0 0 10px var(--glow));}
.panel-date{font-family:'Jost',sans-serif;font-size:0.62rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin-bottom:0.4rem;}
.panel-sign{font-family:'Cinzel',serif;font-size:1.3rem;color:var(--gold-pale);margin-bottom:0.8rem;}
.panel-body{font-family:'Cormorant Garamond',serif;font-size:1.05rem;line-height:1.8;color:rgba(216,228,255,0.72);font-style:italic;margin-bottom:1.5rem;}
.panel-meta{font-family:'Jost',sans-serif;font-size:0.7rem;letter-spacing:0.1em;color:rgba(201,168,76,0.55);margin-bottom:1rem;}
.panel-stars{display:flex;gap:3px;}
.star-r{color:var(--gold);font-size:0.75rem;}
.panel-time{display:inline-block;font-family:'Jost',sans-serif;font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--night);background:var(--gold);padding:0.18rem 0.6rem;margin-bottom:1rem;}

/* Source credit */
.source-credit{text-align:center;margin-top:2.5rem;}
.source-credit a{font-family:'Jost',sans-serif;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(201,168,76,0.45);text-decoration:none;transition:color 0.3s;}
.source-credit a:hover{color:var(--gold);}

/* ═══ Tarot Strip ═══ */
.tarot-strip{padding:2rem 0;overflow:hidden;position:relative;}
.tarot-track{display:flex;gap:1.5rem;animation:scroll-left 38s linear infinite;width:max-content;}
.tarot-card{width:130px;height:220px;background:var(--veil);border:1px solid rgba(201,168,76,0.18);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.8rem;flex-shrink:0;position:relative;overflow:hidden;transition:transform 0.3s,border-color 0.3s;}
.tarot-card:hover{transform:translateY(-8px);border-color:var(--gold);}
.tarot-card-bg{position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,168,76,0.06) 0%,transparent 50%);}
.tarot-card-icon{font-size:2.2rem;position:relative;z-index:1;}
.tarot-card-name{font-family:'Cinzel',serif;font-size:0.58rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);text-align:center;position:relative;z-index:1;padding:0 0.8rem;}
.tarot-strip::before,.tarot-strip::after{content:'';position:absolute;top:0;width:100px;height:100%;z-index:2;pointer-events:none;}
.tarot-strip::before{left:0;background:linear-gradient(to right,var(--night),transparent);}
.tarot-strip::after{right:0;background:linear-gradient(to left,var(--night),transparent);}

/* ═══ Services ═══ */
.services{padding:7rem 4rem;max-width:1200px;margin:0 auto;}
.services-header{text-align:center;margin-bottom:4.5rem;}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;}
.service-card{background:var(--cosmos);border:1px solid rgba(201,168,76,0.1);padding:2.5rem 2rem;position:relative;overflow:hidden;transition:all 0.4s;cursor:none;}
.service-card:hover{border-color:rgba(201,168,76,0.38);transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,0.3);}
.service-card.featured{background:linear-gradient(135deg,rgba(201,168,76,0.1) 0%,var(--cosmos) 50%);border-color:rgba(201,168,76,0.3);}
.service-badge{font-family:'Jost',sans-serif;font-size:0.58rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--night);background:var(--gold);padding:0.28rem 0.75rem;display:inline-block;margin-bottom:1.3rem;}
.service-icon{font-size:2.2rem;display:block;margin-bottom:1.2rem;filter:drop-shadow(0 0 8px rgba(201,168,76,0.28));}
.service-name{font-family:'Cinzel',serif;font-size:0.92rem;font-weight:600;color:var(--gold-pale);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.4rem;}
.service-tagline{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.95rem;color:rgba(216,228,255,0.55);margin-bottom:1.2rem;}
.service-desc{font-size:0.82rem;line-height:1.8;color:rgba(216,228,255,0.5);margin-bottom:1.5rem;}
.service-price{font-family:'Cinzel',serif;font-size:1.7rem;color:var(--gold);margin-bottom:0.2rem;}
.service-price-note{font-size:0.68rem;letter-spacing:0.15em;color:rgba(216,228,255,0.35);text-transform:uppercase;margin-bottom:1.5rem;}
.service-features{list-style:none;margin-bottom:2rem;}
.service-features li{font-size:0.8rem;color:rgba(216,228,255,0.55);padding:0.35rem 0;border-bottom:1px solid rgba(201,168,76,0.07);display:flex;align-items:center;gap:0.7rem;}
.service-features li::before{content:'✦';color:var(--gold);font-size:0.48rem;flex-shrink:0;}
.btn-service{width:100%;font-family:'Jost',sans-serif;font-size:0.68rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;padding:0.85rem;border:1px solid rgba(201,168,76,0.38);color:var(--gold);background:transparent;cursor:none;transition:all 0.3s;text-align:center;display:block;text-decoration:none;}
.btn-service:hover{background:var(--gold);color:var(--night);}
.service-card.featured .btn-service{background:var(--gold);color:var(--night);border-color:var(--gold);}
.service-card.featured .btn-service:hover{background:var(--gold-lt);}

/* ═══ Parties ═══ */
.parties{padding:7rem 4rem;background:linear-gradient(to bottom,transparent,var(--deep),transparent);}
.parties-inner{max-width:1200px;margin:0 auto;}
.parties-layout{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-top:4.5rem;}
.parties-lead{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-style:italic;line-height:1.8;color:rgba(216,228,255,0.72);margin:1.3rem 0 2rem;}
.party-options{display:flex;flex-direction:column;gap:0.8rem;margin-bottom:2.5rem;}
.party-option{display:flex;gap:1.2rem;align-items:flex-start;padding:1.3rem;background:rgba(201,168,76,0.04);border:1px solid rgba(201,168,76,0.1);transition:all 0.3s;cursor:none;}
.party-option:hover{background:rgba(201,168,76,0.07);border-color:rgba(201,168,76,0.28);}
.party-option-icon{font-size:1.6rem;flex-shrink:0;margin-top:0.15rem;}
.party-option-name{font-family:'Cinzel',serif;font-size:0.8rem;color:var(--gold-pale);letter-spacing:0.08em;margin-bottom:0.25rem;}
.party-option-desc{font-size:0.8rem;color:rgba(216,228,255,0.48);line-height:1.6;}
.party-option-price{font-family:'Cinzel',serif;color:var(--gold);font-size:0.85rem;margin-top:0.35rem;}
.moon-circle{width:380px;height:380px;border-radius:50%;border:1px solid rgba(201,168,76,0.18);display:flex;align-items:center;justify-content:center;position:relative;margin:0 auto;}
.moon-circle::before{content:'';position:absolute;inset:18px;border-radius:50%;border:1px solid rgba(201,168,76,0.08);}
.moon-inner{width:260px;height:260px;border-radius:50%;background:radial-gradient(circle at 35% 35%,rgba(201,168,76,0.22),rgba(201,168,76,0.04) 60%,transparent);border:1px solid rgba(201,168,76,0.22);display:flex;align-items:center;justify-content:center;font-size:7rem;}
.orbit-dot{position:absolute;width:7px;height:7px;border-radius:50%;background:var(--gold);filter:drop-shadow(0 0 5px var(--gold));}
.o1{animation:orbit 8s linear infinite;transform-origin:190px 190px;}
.o2{animation:orbit 13s linear infinite reverse;transform-origin:190px 190px;width:5px;height:5px;opacity:0.6;}
.o3{animation:orbit 22s linear infinite;transform-origin:190px 190px;width:4px;height:4px;background:var(--blush);}

/* ═══ Booking ═══ */
.booking{padding:7rem 4rem;max-width:900px;margin:0 auto;}
.booking-header{text-align:center;margin-bottom:4.5rem;}
.booking-form{background:var(--cosmos);border:1px solid rgba(201,168,76,0.14);padding:3.5rem;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1.3rem;margin-bottom:1.3rem;}
.form-group{display:flex;flex-direction:column;gap:0.45rem;}
.form-group.full{grid-column:1/-1;}
.form-label{font-family:'Jost',sans-serif;font-size:0.62rem;font-weight:500;letter-spacing:0.24em;text-transform:uppercase;color:rgba(201,168,76,0.65);}
.form-input,.form-select,.form-textarea{background:rgba(255,255,255,0.04);border:1px solid rgba(201,168,76,0.14);color:var(--moon);font-family:'Jost',sans-serif;font-size:0.88rem;padding:0.8rem 1rem;outline:none;transition:border-color 0.3s,background 0.3s;-webkit-appearance:none;cursor:none;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:rgba(201,168,76,0.45);background:rgba(201,168,76,0.04);}
.form-select option{background:var(--deep);}
.form-textarea{resize:none;height:90px;}
.session-picker{display:grid;grid-template-columns:repeat(3,1fr);gap:0.8rem;margin-bottom:1.8rem;}
.session-option{border:1px solid rgba(201,168,76,0.14);padding:1.1rem;text-align:center;cursor:none;transition:all 0.3s;position:relative;}
.session-option:hover,.session-option.active{border-color:var(--gold);background:rgba(201,168,76,0.07);}
.session-option.active::after{content:'✦';position:absolute;top:0.4rem;right:0.5rem;color:var(--gold);font-size:0.55rem;}
.session-option-icon{font-size:1.4rem;margin-bottom:0.4rem;}
.session-option-name{font-family:'Cinzel',serif;font-size:0.6rem;color:var(--gold-pale);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.2rem;}
.session-option-price{font-size:0.78rem;color:var(--gold);font-family:'Cormorant Garamond',serif;}
.payment-area{border-top:1px solid rgba(201,168,76,0.1);padding-top:1.8rem;margin-top:1.8rem;}
.payment-title{font-family:'Cinzel',serif;font-size:0.75rem;letter-spacing:0.2em;color:var(--gold);margin-bottom:1.3rem;text-transform:uppercase;}
.card-icons{display:flex;gap:0.6rem;margin-bottom:1.3rem;}
.card-icon{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);padding:0.3rem 0.55rem;font-size:0.62rem;letter-spacing:0.08em;color:rgba(216,228,255,0.38);}
.total-row{display:flex;justify-content:space-between;align-items:center;padding:1.3rem 0;border-top:1px solid rgba(201,168,76,0.1);margin:1.3rem 0;}
.total-label{font-family:'Jost',sans-serif;font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(216,228,255,0.45);}
.total-amount{font-family:'Cinzel',serif;font-size:1.7rem;color:var(--gold);}
.btn-book{width:100%;font-family:'Cinzel',serif;font-size:0.82rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(--night);background:var(--gold);padding:1.1rem;border:none;cursor:none;transition:all 0.3s;}
.btn-book:hover{background:var(--gold-lt);transform:translateY(-2px);box-shadow:0 10px 28px rgba(201,168,76,0.18);}

/* ═══ Testimonials ═══ */
.testimonials{padding:7rem 4rem;background:linear-gradient(to bottom,transparent,var(--deep),transparent);}
.testimonials-inner{max-width:1100px;margin:0 auto;}
.testimonials-header{text-align:center;margin-bottom:4.5rem;}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;}
.testi-card{background:var(--cosmos);border:1px solid rgba(201,168,76,0.09);padding:2.2rem;position:relative;overflow:hidden;transition:all 0.3s;}
.testi-card:hover{border-color:rgba(201,168,76,0.28);}
.testi-glyph{position:absolute;top:-10px;right:1.3rem;font-size:5.5rem;color:rgba(201,168,76,0.04);font-family:'Cinzel',serif;line-height:1;pointer-events:none;}
.testi-stars{color:var(--gold);font-size:0.72rem;letter-spacing:0.18em;margin-bottom:1rem;}
.testi-quote{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;line-height:1.8;color:rgba(216,228,255,0.68);margin-bottom:1.7rem;}
.testi-author{font-family:'Cinzel',serif;font-size:0.67rem;color:var(--gold);letter-spacing:0.14em;text-transform:uppercase;}
.testi-sign{font-family:'Jost',sans-serif;font-size:0.67rem;color:rgba(216,228,255,0.33);margin-top:0.2rem;}

/* ═══ Footer ═══ */
footer{padding:5rem 4rem 2.5rem;border-top:1px solid rgba(201,168,76,0.08);position:relative;z-index:1;}
.footer-inner{max-width:1200px;margin:0 auto;}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:4rem;margin-bottom:4rem;}
.footer-brand-name{font-family:'Cinzel',serif;font-size:1rem;color:var(--gold);letter-spacing:0.1em;margin-bottom:0.8rem;}
.footer-brand-desc{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.95rem;line-height:1.8;color:rgba(216,228,255,0.42);margin-bottom:1.3rem;}
.footer-social{display:flex;gap:0.7rem;}
.social-btn{width:34px;height:34px;border:1px solid rgba(201,168,76,0.18);display:flex;align-items:center;justify-content:center;font-size:0.75rem;color:rgba(216,228,255,0.38);text-decoration:none;transition:all 0.3s;}
.social-btn:hover{border-color:var(--gold);color:var(--gold);}
.footer-col-title{font-family:'Cinzel',serif;font-size:0.65rem;color:var(--gold);letter-spacing:0.25em;text-transform:uppercase;margin-bottom:1.3rem;}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:0.7rem;}
.footer-links a{font-size:0.8rem;color:rgba(216,228,255,0.38);text-decoration:none;transition:color 0.3s;}
.footer-links a:hover{color:var(--gold-lt);}
.footer-bottom{border-top:1px solid rgba(201,168,76,0.06);padding-top:1.8rem;display:flex;justify-content:space-between;align-items:center;}
.footer-copy{font-size:0.68rem;color:rgba(216,228,255,0.22);letter-spacing:0.1em;}
.footer-tagline{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.85rem;color:rgba(201,168,76,0.32);}

.btn-primary{font-family:'Jost',sans-serif;font-size:0.72rem;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;color:var(--night);background:var(--gold);padding:0.95rem 2.2rem;text-decoration:none;border:none;cursor:none;transition:all 0.3s;display:inline-block;}
.btn-primary:hover{background:var(--gold-lt);transform:translateY(-2px);}

.modal-overlay{display:none;position:fixed;inset:0;z-index:1000;background:rgba(30,39,64,0.9);align-items:center;justify-content:center;backdrop-filter:blur(8px);}
.modal-overlay.open{display:flex;}
.modal{background:var(--cosmos);border:1px solid rgba(201,168,76,0.22);padding:2.8rem;max-width:460px;width:90%;position:relative;animation:fadeUp 0.35s forwards;}
.modal-close{position:absolute;top:1rem;right:1.3rem;background:none;border:none;cursor:none;color:rgba(216,228,255,0.38);font-size:1.1rem;transition:color 0.3s;}
.modal-close:hover{color:var(--gold);}
.modal-title{font-family:'Cinzel',serif;font-size:1.1rem;color:var(--gold-pale);margin-bottom:0.4rem;}
.modal-body{font-size:0.83rem;line-height:1.8;color:rgba(216,228,255,0.58);}

.reveal{opacity:0;transform:translateY(36px);transition:opacity 0.8s ease,transform 0.8s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-delay-1{transition-delay:0.1s;}
.reveal-delay-2{transition-delay:0.2s;}
.reveal-delay-3{transition-delay:0.3s;}

@keyframes fadeUp{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:translateY(0);}}
@keyframes scroll-left{from{transform:translateX(0);}to{transform:translateX(-50%);}}
@keyframes orbit{from{transform:rotate(0deg) translateX(190px) rotate(0deg);}to{transform:rotate(360deg) translateX(190px) rotate(-360deg);}}
@keyframes scroll-pulse{0%,100%{opacity:0.3;}50%{opacity:1;}}
@keyframes pulse-hint{0%,100%{opacity:0.5;transform:translateY(0);}50%{opacity:1;transform:translateY(3px);}}

@media(max-width:900px){
  nav{padding:1.1rem 1.5rem;}
  .nav-links{display:none;}
  .daily-grid,.services-grid,.testi-grid{grid-template-columns:1fr;}
  .parties-layout{grid-template-columns:1fr;}
  .parties-visual{display:none;}
  .footer-top{grid-template-columns:1fr 1fr;gap:2rem;}
  .form-row{grid-template-columns:1fr;}
  .session-picker{grid-template-columns:1fr;}
  .daily,.services,.parties,.booking,.testimonials{padding:5rem 1.5rem;}
  .booking-form{padding:2rem;}
  .hero-title h1{font-size:clamp(2.5rem,11vw,5rem);}
  .hero-eyebrow{font-size:0.82rem;letter-spacing:0.25em;}
  .hero-hint{font-size:0.78rem;letter-spacing:0.2em;}
  .section-label{font-size:0.78rem;letter-spacing:0.3em;}
  .nav-logo{font-size:1.05rem;}
  .nav-cta{font-size:0.82rem;padding:0.65rem 1.6rem;}
  .photo-credit{font-size:0.65rem;}
}
</style>
</head>
<body>
<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">{{ site.nav.logoText }}<span>{{ site.nav.logoSpan }}</span></a>
  <ul class="nav-links">
    {% for link in site.nav.links %}
    <li><a href="{{ link.href }}">{{ link.text }}</a></li>
    {% endfor %}
  </ul>
  <a href="{{ site.nav.ctaHref }}" class="nav-cta">{{ site.nav.ctaText }}</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-kailash"></div>
  <div class="hero-tint"></div>
  <canvas id="constellationCanvas"></canvas>
  <div class="hero-title">
    <p class="hero-eyebrow">{{ site.hero.eyebrow }}</p>
    <h1>{{ site.hero.titleLine1 }}<em>{{ site.hero.titleLine2 }}</em></h1>
    <p class="hero-hint"><span>{{ site.hero.hint }}</span></p>
  </div>
  <div class="star-tooltip" id="starTooltip">
    <p class="star-tooltip-label" id="tooltipLabel">&ndash;</p>
    <p class="star-tooltip-desc" id="tooltipDesc">&ndash;</p>
    <p class="star-tooltip-cta">Click to explore &rarr;</p>
  </div>
  <p class="photo-credit">{{ site.hero.photoCredit }}</p>
  <div class="scroll-down"><div class="scroll-down-line"></div></div>
</section>

<!-- DAILY COSMIC -->
<section class="daily" id="daily">
  <div class="daily-inner">
    <div class="daily-header reveal">
      <p class="section-label">{{ site.daily.sectionLabel }}</p>
      <h2 class="section-title">{{ site.daily.sectionTitle }} <em>{{ site.daily.sectionTitleEmphasis }}</em></h2>
      <div class="divider"></div>
      <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.05rem;color:rgba(216,228,255,0.5);max-width:560px;margin:0 auto;">
        {{ site.daily.cosmicSummaryLine1 }}<br>
        {{ site.daily.cosmicSummaryLine2 }}
      </p>
    </div>

    <!-- Mercury retrograde warning -->
    <div class="retro-alert reveal">
      <span class="retro-alert-icon">{{ site.daily.retroAlert.icon }}</span>
      <p class="retro-alert-text">
        <strong>{{ site.daily.retroAlert.title }}</strong>
        {{ site.daily.retroAlert.body }}
      </p>
    </div>

    <div class="daily-grid reveal">
      {% for panel in site.daily.panels %}
      <div class="daily-panel">
        <span class="panel-icon">{{ panel.icon }}</span>
        <p class="panel-date">{{ panel.date }}</p>
        <p class="panel-sign">{{ panel.sign }}</p>
        {% if panel.time %}
        <span class="panel-time">{{ panel.time }}</span>
        {% endif %}
        <p class="panel-body">{{ panel.body }}</p>
        <p class="panel-meta">{{ panel.meta }}</p>
        <div class="panel-stars">
          {% for i in range(0, panel.stars) %}<span class="star-r">&#9733;</span>{% endfor %}
          {% for i in range(0, 5 - panel.stars) %}<span class="star-r" style="opacity:0.3">&#9733;</span>{% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="source-credit">
      <a href="{{ site.daily.sourceCredit.href }}" target="_blank" rel="noopener">
        {{ site.daily.sourceCredit.text }}
      </a>
    </div>

  </div>
</section>

<!-- TAROT STRIP -->
<div class="tarot-strip">
  <div class="tarot-track">
    {# Render twice for infinite scroll effect #}
    {% for card in site.tarotStrip %}
    <div class="tarot-card"><div class="tarot-card-bg"></div><span class="tarot-card-icon">{{ card.icon }}</span><span class="tarot-card-name">{{ card.name }}</span></div>
    {% endfor %}
    {% for card in site.tarotStrip %}
    <div class="tarot-card"><div class="tarot-card-bg"></div><span class="tarot-card-icon">{{ card.icon }}</span><span class="tarot-card-name">{{ card.name }}</span></div>
    {% endfor %}
  </div>
</div>

<!-- SERVICES -->
<section class="services" id="services">
  <div class="services-header reveal">
    <p class="section-label">{{ site.services.sectionLabel }}</p>
    <h2 class="section-title">{{ site.services.sectionTitle }} <em>{{ site.services.sectionTitleEmphasis }}</em></h2>
    <div class="divider"></div>
  </div>
  <div class="services-grid">
    {% for service in site.services.items %}
    <div class="service-card{% if service.featured %} featured{% endif %} reveal{% if loop.index0 % 3 == 1 %} reveal-delay-1{% elif loop.index0 % 3 == 2 %} reveal-delay-2{% endif %}">
      {% if service.badge %}
      <span class="service-badge">{{ service.badge }}</span>
      {% endif %}
      <span class="service-icon">{{ service.icon }}</span>
      <p class="service-name">{{ service.name }}</p>
      <p class="service-tagline">{{ service.tagline }}</p>
      <p class="service-desc">{{ service.description }}</p>
      <p class="service-price">{{ service.price }}</p>
      <p class="service-price-note">{{ service.priceNote }}</p>
      <ul class="service-features">
        {% for feature in service.features %}
        <li>{{ feature }}</li>
        {% endfor %}
      </ul>
      <a href="#booking" class="btn-service">{{ service.buttonText }}</a>
    </div>
    {% endfor %}
  </div>
</section>

<!-- PARTIES -->
<section class="parties" id="parties">
  <div class="parties-inner">
    <div class="reveal" style="text-align:center">
      <p class="section-label">{{ site.parties.sectionLabel }}</p>
      <h2 class="section-title">{{ site.parties.sectionTitle }} <em>{{ site.parties.sectionTitleEmphasis }}</em></h2>
      <div class="divider"></div>
    </div>
    <div class="parties-layout">
      <div class="parties-text reveal">
        <p class="parties-lead">{{ site.parties.lead }}</p>
        <div class="party-options">
          {% for option in site.parties.options %}
          <div class="party-option"><span class="party-option-icon">{{ option.icon }}</span><div><p class="party-option-name">{{ option.name }}</p><p class="party-option-desc">{{ option.description }}</p><p class="party-option-price">{{ option.price }}</p></div></div>
          {% endfor %}
        </div>
        <a href="#booking" class="btn-primary">{{ site.parties.ctaText }}</a>
      </div>
      <div class="parties-visual reveal">
        <div class="moon-circle">
          <div class="moon-inner">&#127765;</div>
          <div class="orbit-dot o1" style="top:190px;left:0;"></div>
          <div class="orbit-dot o2" style="top:190px;left:0;"></div>
          <div class="orbit-dot o3" style="top:190px;left:0;"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- BOOKING -->
<section class="booking" id="booking">
  <div class="booking-header reveal">
    <p class="section-label">{{ site.booking.sectionLabel }}</p>
    <h2 class="section-title">{{ site.booking.sectionTitle }} <em>{{ site.booking.sectionTitleEmphasis }}</em></h2>
    <div class="divider"></div>
    <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.05rem;color:rgba(216,228,255,0.5);max-width:480px;margin:0 auto;">{{ site.booking.subtitle }}</p>
  </div>
  <form class="booking-form reveal" name="booking" method="POST" data-netlify="true" netlify-honeypot="bot-field">
    <input type="hidden" name="form-name" value="booking">
    <p style="display:none"><label>Don't fill this out: <input name="bot-field"></label></p>
    <input type="hidden" name="session-type" id="sessionType" value="Tarot Reading">
    <div class="form-row"><div class="form-group"><label class="form-label">First Name</label><input type="text" name="first-name" class="form-input" placeholder="Your first name" required></div><div class="form-group"><label class="form-label">Last Name</label><input type="text" name="last-name" class="form-input" placeholder="Your last name" required></div></div>
    <div class="form-row"><div class="form-group"><label class="form-label">Email</label><input type="email" name="email" class="form-input" placeholder="your@email.com" required></div><div class="form-group"><label class="form-label">Phone (optional)</label><input type="tel" name="phone" class="form-input" placeholder="(555) 555-5555"></div></div>
    <div class="form-row"><div class="form-group"><label class="form-label">Date of Birth</label><input type="date" name="dob" class="form-input"></div><div class="form-group"><label class="form-label">Birth Time (if known)</label><input type="time" name="birth-time" class="form-input"></div></div>
    <div class="form-row"><div class="form-group full"><label class="form-label">Birth City</label><input type="text" name="birth-city" class="form-input" placeholder="City, Country"></div></div>
    <p class="form-label" style="margin-bottom:0.9rem;">{{ site.booking.sessionPickerLabel }}</p>
    <div class="session-picker" id="sessionPicker">
      <div class="session-option active" data-name="Tarot Reading" onclick="selectSession(this)"><div class="session-option-icon">🔮</div><div class="session-option-name">Tarot Reading</div><div class="session-option-price">$120</div></div>
      <div class="session-option" data-name="Birth Chart and Interpretation" onclick="selectSession(this)"><div class="session-option-icon">⭐</div><div class="session-option-name">Birth Chart</div><div class="session-option-price">$175</div></div>
      <div class="session-option" data-name="Synastry" onclick="selectSession(this)"><div class="session-option-icon">✨</div><div class="session-option-name">Synastry</div><div class="session-option-price">$180</div></div>
      <div class="session-option" data-name="Triad Bundle" onclick="selectSession(this)"><div class="session-option-icon">📦</div><div class="session-option-name">Triad Bundle</div><div class="session-option-price">$200</div></div>
      <div class="session-option" data-name="Group Session" onclick="selectSession(this)"><div class="session-option-icon">👥</div><div class="session-option-name">Group Session</div><div class="session-option-price">$95 / person</div></div>
      <div class="session-option" data-name="Monthly Forecast" onclick="selectSession(this)"><div class="session-option-icon">🌙</div><div class="session-option-name">Monthly Forecast</div><div class="session-option-price">$55</div></div>
      <div class="session-option" data-name="Astrolocation Reading" onclick="selectSession(this)"><div class="session-option-icon">🌍</div><div class="session-option-name">Astrolocation</div><div class="session-option-price">$150</div></div>
      <div class="session-option" data-name="Astrology for the Month" onclick="selectSession(this)"><div class="session-option-icon">♈</div><div class="session-option-name">Monthly Astrology</div><div class="session-option-price">$80</div></div>
      <div class="session-option" data-name="Yearly Report" onclick="selectSession(this)"><div class="session-option-icon">🌟</div><div class="session-option-name">Yearly Report</div><div class="session-option-price">$200</div></div>
    </div>
    <div class="form-row"><div class="form-group full"><label class="form-label">What brings you here? (Optional)</label><textarea name="message" class="form-textarea" placeholder="A question you're sitting with, a theme, or simply how you're feeling..."></textarea></div></div>
    <button type="submit" class="btn-book">{{ site.booking.bookButtonText }}</button>
  </form>
</section>

<!-- TESTIMONIALS -->
<section class="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-header reveal">
      <p class="section-label">{{ site.testimonials.sectionLabel }}</p>
      <h2 class="section-title">{{ site.testimonials.sectionTitle }} <em>{{ site.testimonials.sectionTitleEmphasis }}</em></h2>
      <div class="divider"></div>
    </div>
    <div class="testi-grid">
      {% for testi in site.testimonials.items %}
      <div class="testi-card reveal{% if loop.index0 == 1 %} reveal-delay-1{% elif loop.index0 == 2 %} reveal-delay-2{% endif %}">
        <div class="testi-glyph">{{ testi.glyph }}</div>
        <div class="testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="testi-quote">{{ testi.quote }}</p>
        <p class="testi-author">{{ testi.author }}</p>
        <p class="testi-sign">{{ testi.signInfo }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <p class="footer-brand-name">{{ site.footer.brandName }}</p>
        <p class="footer-brand-desc">{{ site.footer.brandDesc }}</p>
        <div class="footer-social">
          {% for social in site.footer.socialLinks %}
          <a href="{{ social.href }}" class="social-btn">{{ social.icon }}</a>
          {% endfor %}
        </div>
      </div>
      {% for col in site.footer.navColumns %}
      <div>
        <p class="footer-col-title">{{ col.title }}</p>
        <ul class="footer-links">
          {% for link in col.links %}
          <li><a href="{{ link.href }}">{{ link.text }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">{{ site.footer.copyright }}</p>
      <p class="footer-tagline">{{ site.footer.tagline }}</p>
    </div>
  </div>
</footer>

<div class="modal-overlay" id="confirmModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">&#10005;</button>
    <span style="font-size:2.8rem;display:block;margin-bottom:0.8rem;">&#10022;</span>
    <p class="modal-title">{{ site.confirmationModal.title }}</p>
    <div class="divider" style="margin:0.8rem 0;"></div>
    <p class="modal-body">{{ site.confirmationModal.body }}</p>
    <button onclick="closeModal()" class="btn-primary" style="margin-top:1.5rem;border:none;width:100%;text-align:center;">Close</button>
  </div>
</div>

<script>
/* Cursor */
const cursor=document.getElementById('cursor'),ring=document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});
(function animRing(){rx+=(mx-rx)*0.15;ry+=(my-ry)*0.15;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animRing);})();
document.querySelectorAll('a,button,.service-card,.party-option,.session-option,.tarot-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cursor.style.transform='translate(-50%,-50%) scale(2)';ring.style.transform='translate(-50%,-50%) scale(1.5)';});
  el.addEventListener('mouseleave',()=>{cursor.style.transform='translate(-50%,-50%) scale(1)';ring.style.transform='translate(-50%,-50%) scale(1)';});
});

/* Scroll Reveal */
const ro=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible');}),{threshold:0.1});
document.querySelectorAll('.reveal').forEach(r=>ro.observe(r));

/* Booking */
function selectSession(el){document.querySelectorAll('.session-option').forEach(o=>o.classList.remove('active'));el.classList.add('active');document.getElementById('sessionType').value=el.dataset.name;}
function showConfirmation(){document.getElementById('confirmModal').classList.add('open');}
function closeModal(){document.getElementById('confirmModal').classList.remove('open');}
document.getElementById('confirmModal').addEventListener('click',function(e){if(e.target===this)closeModal();});

/* ═══════════════════════════
   CONSTELLATION HERO
   ═══════════════════════════ */
const cvs=document.getElementById('constellationCanvas');
const ctx=cvs.getContext('2d');
const tooltip=document.getElementById('starTooltip');
const ttLabel=document.getElementById('tooltipLabel');
const ttDesc=document.getElementById('tooltipDesc');

function resizeCvs(){cvs.width=cvs.offsetWidth;cvs.height=cvs.offsetHeight;}
resizeCvs();

const nodes={{ site.hero.constellationNodes | dump | safe }};
const lines={{ site.hero.constellationLines | dump | safe }};

let bgStars=[];
function genBg(){
  bgStars=[];
  for(let i=0;i<180;i++) bgStars.push({x:Math.random()*cvs.width,y:Math.random()*cvs.height,r:Math.random()*1.1+0.2,tw:Math.random()*Math.PI*2,sp:Math.random()*0.015+0.004});
}
genBg();

let hovNode=null,t=0;
function npos(n){return{x:n.px*cvs.width,y:n.py*cvs.height};}

function draw(){
  ctx.clearRect(0,0,cvs.width,cvs.height);
  t+=0.012;

  bgStars.forEach(s=>{
    const a=0.1+Math.sin(t*s.sp*55+s.tw)*0.35;
    ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(201,168,76,${Math.max(0.04,a)})`;ctx.fill();
  });

  lines.forEach(([a,b])=>{
    const na=nodes.find(n=>n.id===a),nb=nodes.find(n=>n.id===b);
    if(!na||!nb)return;
    const pa=npos(na),pb=npos(nb);
    const g=ctx.createLinearGradient(pa.x,pa.y,pb.x,pb.y);
    g.addColorStop(0,'rgba(201,168,76,0.14)');g.addColorStop(0.5,'rgba(201,168,76,0.3)');g.addColorStop(1,'rgba(201,168,76,0.14)');
    ctx.beginPath();ctx.moveTo(pa.x,pa.y);ctx.lineTo(pb.x,pb.y);
    ctx.strokeStyle=g;ctx.lineWidth=0.8;ctx.setLineDash([4,7]);ctx.stroke();ctx.setLineDash([]);
  });

  nodes.forEach(n=>{
    const p=npos(n),hov=(hovNode===n);
    const pulse=Math.sin(t+n.px*9)*0.22+1;
    const br=n.r*pulse;
    const grd=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,hov?60:38);
    grd.addColorStop(0,hov?'rgba(201,168,76,0.6)':'rgba(201,168,76,0.22)');
    grd.addColorStop(1,'rgba(201,168,76,0)');
    ctx.beginPath();ctx.arc(p.x,p.y,hov?60:38,0,Math.PI*2);ctx.fillStyle=grd;ctx.fill();
    ctx.beginPath();ctx.arc(p.x,p.y,hov?br*1.6:br,0,Math.PI*2);
    ctx.fillStyle=hov?'#f5e6b8':'#c9a84c';
    ctx.shadowColor='#c9a84c';ctx.shadowBlur=hov?22:10;ctx.fill();ctx.shadowBlur=0;
    if(hov){
      ctx.save();ctx.strokeStyle='rgba(245,230,184,0.75)';ctx.lineWidth=0.9;
      const sc=br*2.8;
      ctx.beginPath();ctx.moveTo(p.x-sc,p.y);ctx.lineTo(p.x+sc,p.y);ctx.stroke();
      ctx.beginPath();ctx.moveTo(p.x,p.y-sc);ctx.lineTo(p.x,p.y+sc);ctx.stroke();
      ctx.restore();
    }
    ctx.font=`${hov?'500':'300'} ${cvs.width<600?'0.52rem':'0.6rem'} 'Jost',sans-serif`;
    ctx.fillStyle=hov?'rgba(245,230,184,1)':'rgba(201,168,76,0.6)';
    ctx.textAlign='center';
    ctx.fillText(n.label.toUpperCase(),p.x,p.y+br+16);
  });

  requestAnimationFrame(draw);
}
draw();

cvs.addEventListener('mousemove',e=>{
  const rect=cvs.getBoundingClientRect(),mx=e.clientX-rect.left,my=e.clientY-rect.top;
  let found=null;
  nodes.forEach(n=>{const p=npos(n);if(Math.hypot(mx-p.x,my-p.y)<n.r+24)found=n;});
  hovNode=found;
  if(found){
    const p=npos(found);
    let tx=p.x+28,ty=p.y-12;
    if(tx+230>cvs.width)tx=p.x-240;
    if(ty+85>cvs.height)ty=p.y-95;
    tooltip.style.left=tx+'px';tooltip.style.top=ty+'px';
    ttLabel.textContent=found.label;ttDesc.textContent=found.desc;
    tooltip.classList.add('visible');
    cursor.style.transform='translate(-50%,-50%) scale(2)';
    ring.style.transform='translate(-50%,-50%) scale(1.5)';
  } else {
    tooltip.classList.remove('visible');
    cursor.style.transform='translate(-50%,-50%) scale(1)';
    ring.style.transform='translate(-50%,-50%) scale(1)';
  }
});
cvs.addEventListener('mouseleave',()=>{hovNode=null;tooltip.classList.remove('visible');});
cvs.addEventListener('click',()=>{if(hovNode){const t=document.querySelector(hovNode.href);if(t)t.scrollIntoView({behavior:'smooth'});}});
cvs.addEventListener('touchend',e=>{
  e.preventDefault();
  const touch=e.changedTouches[0];
  const rect=cvs.getBoundingClientRect();
  const tx=touch.clientX-rect.left,ty=touch.clientY-rect.top;
  nodes.forEach(n=>{const p=npos(n);if(Math.hypot(tx-p.x,ty-p.y)<n.r+32){const tgt=document.querySelector(n.href);if(tgt)tgt.scrollIntoView({behavior:'smooth'});}});
},{passive:false});
window.addEventListener('resize',()=>{resizeCvs();genBg();});
</script>
</body>
</html>